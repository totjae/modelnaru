{
  "name": "@modelnaru/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "node --watch --import tsx src/main.ts",
    "start": "node --enable-source-maps dist/main.js",
