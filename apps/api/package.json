    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@modelnaru/config": "workspace:*",
    "@nestjs/common": "^11.1.28",
    "@nestjs/core": "^11.1.28",
    "@nestjs/platform-express": "^11.1.28",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "tsx": "^4.20.3"
  }
}
